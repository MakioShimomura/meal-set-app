.row
  .col-12.col-md-6.col-lg-4.m-auto
    %h2.fs-4.text-center.mb-4 新規登録
    = simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
      .form-inputs
        = f.input :email, required: true, autofocus: true, input_html: { autocomplete: 'email' }
        = f.input :password, required: true, input_html: { autocomplete: 'new-password' }
        = f.input :password_confirmation, required: true, input_html: { autocomplete: 'new-password' }
      .form-actions
        = f.button :submit, '新規登録', class: 'btn-primary w-100'
    .mt-4.text-center
      = link_to 'ログイン', new_session_path(resource_name)
