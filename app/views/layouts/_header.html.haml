%header.navbar.navbar-expand-lg.bg-body-tertiary
  .container-fluid
    = link_to 'Meal Set App', root_path, class: 'navbar-brand'
    %button.navbar-toggler{ type: 'button', data: { bs_toggle: 'collapse', bs_target: '#navbar' }, aria: { controls: 'navbar' } }
      %span.navbar-toggler-icon
    #navbar.collapse.navbar-collapse
      %ul.navbar-nav.ms-auto
        %li.nav-item
          = button_to 'ログアウト', destroy_user_session_path, method: :delete, class: 'nav-link', data: { turbo_method: :delete }
